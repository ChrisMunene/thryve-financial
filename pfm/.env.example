ENVIRONMENT=development
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pfm
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

REDIS_URL=redis://localhost:6380/0
REDIS_CACHE_TTL=86400

AUTH_SUPABASE_JWT_SECRET=
AUTH_SUPABASE_URL=
AUTH_SUPABASE_JWKS_URL=

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_RETRIES=3

OTEL_TRACES_EXPORTER=console
OTEL_METRICS_EXPORTER=console
OTEL_LOGS_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_INSECURE=false
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_BSP_SCHEDULE_DELAY=5000
OTEL_BSP_EXPORT_TIMEOUT=30000
OTEL_BSP_MAX_QUEUE_SIZE=2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
OTEL_METRIC_EXPORT_INTERVAL=30000
OTEL_PYTHON_FASTAPI_EXCLUDED_URLS=/api/v1/health,/api/v1/health/ready,/docs,/openapi.json
OTEL_RESOURCE_ATTRIBUTES=region=local
OTEL_SERVICE_NAMESPACE=pfm
OTEL_SERVICE_NAME_API=pfm-api
OTEL_SERVICE_NAME_WORKER=pfm-worker
OTEL_SERVICE_NAME_BEAT=pfm-beat
OTEL_LOG_LEVEL=DEBUG

POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_WRITE_LIMIT=30
RATE_LIMIT_WRITE_WINDOW_SECONDS=60
RATE_LIMIT_EXPENSIVE_LIMIT=10
RATE_LIMIT_EXPENSIVE_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
