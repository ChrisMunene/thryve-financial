# Environment: development | staging | production
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pfm
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6380/0
REDIS_CACHE_TTL=86400

# Auth (required in staging/production)
AUTH_SUPABASE_JWT_SECRET=
AUTH_SUPABASE_URL=
AUTH_SUPABASE_JWKS_URL=

# Plaid (required in staging/production)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Anthropic (required in staging/production)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_RETRIES=3

# Observability
OTEL_EXPORTER=console
OTEL_ENDPOINT=
OTEL_LOG_LEVEL=DEBUG
OTEL_POSTHOG_API_KEY=
OTEL_POSTHOG_HOST=https://app.posthog.com

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
RATE_LIMIT_DEFAULT=100
REQUEST_TIMEOUT=30
REQUEST_MAX_BODY_SIZE=1048576
SHUTDOWN_TIMEOUT=15

# Engine
DETERMINISTIC_CONFIDENCE_THRESHOLD=0.8
LLM_CONFIDENCE_THRESHOLD=0.8
IDEMPOTENCY_TTL=86400
